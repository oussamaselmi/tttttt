_10"}],"thematicTags":[{"label":"Iran","tid":"102_D64_1389"},{"label":"Isra\u00ebl","tid":"102_D64_1419"},{"label":"Guerre","tid":"102_D64_19278"},{"label":"Pays du Golfe","tid":"102_D64_19406"},{"label":"\u00c9tats-Unis","tid":"102_D64_2419"},{"label":"Benjamin Netanyahu","tid":"102_D64_17142"}],"multimedia":[]}]}}]},{"organism":"ad-container","position":9,"settings":{"shared":null,"fov":null,"app":{"type":"pub-pave-2","dataTestId":"id_pub-pave-2-hp","is_ignored":false},"bach":{"hidden":true}},"subAreas":[]},{"organism":"aside-content--carousel","position":10,"settings":{"shared":null,"fov":null,"app":{"type":"actu-video","is_ignored":false},"bach":null},"subAreas":[{"organism":null,"position":1,"settings":{"shared":{"title":"L'essentiel du jour","max_content":5,"tracking_code":"daily-news"},"fov":{"max_content":5,"title_align":"left","image_format":"16x9","show_program":true,"title_colored":true,"hide_play_button":true},"app":{"type":"essentiel","dataTestId":"id_essentiel-hp","is_ignored":false},"bach":{"type":"manual_list","uuid":"4f2b5238-ccd8-11ef-83ff-005056bf1351","lastModifiedAt":"2026-03-20T11:25:50+01:00","persistent_iri":true,"is_section_title":true}},"content":{"@type":"Multimedia","title":"layout area subarea 1774002354","entrepriseId":"WB-MZ594142","mainImage":null,"estimatedReadingTime":1230,"canonicalAbsoluteUrl":"","mediaReadingTime":0,"superTags":[],"thematicTags":[],"meManualList":[{"@type":"Article","title":"En direct : Jean-No\u00ebl Barrot prend la parole apr\u00e8s un \u00e9change avec Gideon Saar \u00e0 J\u00e9rusalem","entrepriseId":"WBMZ614925-F24-FR-20260320","mainImage":{"mediaPath":"\/media\/display\/f5bb3c7c-2447-11f1-be15-005056bfb2b6","filenameWithoutExtension":"2026-03-20T092838Z-1732114265-RC288KAAKY8E-RTRMADP-3-IRAN-CRISIS-ISRAEL-FRANCE","originalRatio":1.4993954050786,"filename":"2026-03-20T092838Z-1732114265-RC288KAAKY8E-RTRMADP-3-IRAN-CRISIS-ISRAEL-FRANCE.jpg"},"introduction":"<p>Au 21e jour de la guerre au Moyen-Orient, le ministre\u00a0fran\u00e7ais des Affaires \u00e9trang\u00e8res, Jean-No\u00ebl Barrot, a \u00e9chang\u00e9 vendredi avec son homologue isra\u00e9lien, Gideon Saar, \u00e0 J\u00e9rusalem. Plus t\u00f4t dans la matin\u00e9e, l'arm\u00e9e isra\u00e9lienne a lanc\u00e9 de nouvelles frappes sur des \"infrastructures\" des autorit\u00e9s iraniennes \u00e0 T\u00e9h\u00e9ran. Les Gardiens de la r\u00e9volution ont annonc\u00e9 la mort de leur porte-parole, Ali Mohammad Na\u00efni, dans l'une d'entre elles.\u00a0Suivez notre direct.<\/p>","surtitle":null,"cartouche":null,"cartoucheTags":[],"mainSound":null,"mainVideo":{"youtubeId":"l8PMl7tUDIE"},"estimatedReadingTime":49845,"canonicalAbsoluteUrl":"https:\/\/www.france24.com\/fr\/moyen-orient\/20260320-en-direct-guerre-moyen-orient-iran-israel-etats-unis-golfe-petrole-liban","mediaReadingTime":0,"superTags":[{"label":"Moyen-Orient","tid":"102_D64_10"}],"thematicTags":[{"label":"Iran","tid":"102_D64_1389"},{"label":"Moyen-Orient","tid":"102_D64_21021"},{"label":"Isra\u00ebl","tid":"102_D64_1419"},{"label":"\u00c9tats-Unis","tid":"102_D64_2419"},{"label":"Liban","tid":"102_D64_1549"},{"label":"Hezbollah","tid":"102_D64_14052"},{"label":"Pays du Golfe","tid":"102_D64_19406"}],"multimedia":[{"meLiveBlog":{"provider":"ARENA","providerBlogId":"69bcb1ae8def3251d2cffd06","providerSiteId":"65368d964d3c6f8c98edaddb","providerOrganizationId":"650ac690a98c6e1f4d49ba1a","status":"live","posts":[{"id":"Kj3JsVCVr01efPkRkQAx","body":"<p><em style=\"background-color: rgba(251, 250, 253, 0.196); color: rgb(69, 76, 95);\">Plus d'informations \u00e0 venir...<\/em><\/p>","tags":[],"type":"html","title":"L'Espagne annonce un plan d'aide anti-crise de 80 mesures pour 5 milliards d'euros","priority":"normal","createdAt":"2026-03-20T12:24:58.634000Z","titlelink":"","updatedAt":"2026-03-20T12:24:58.634000Z"},{"id":"GTXJdELGaett8gkSZWSD","body":"<p><em>Plus d'informations \u00e0 venir...<\/em><\/p>","tags":[],"type":"html","title":"L'Otan retire \"temporairement\" sa mission d'Irak, selon des responsables irakiens","priority":"normal","createdAt":"2026-03-20T12:21:34.091000Z","titlelink":"","updatedAt":"2026-03-20T12:24:03.924000Z"},{"id":"3R23s2NkIA0EJZuuAiJZ","body":"","tags":[],"type":"html","title":"Jean-No\u00ebl Barrot prend la parole apr\u00e8s son \u00e9change avec le ministre isra\u00e9lien des Affaires \u00e9trang\u00e8res","priority":"normal","createdAt":"2026-03-20T12:15:38.655000Z","titlelink":"","updatedAt":"2026-03-20T12:15:38.655000Z"},{"id":"1NZHSVIT7jKREEIBhVq3","body":"<p>La police de l'\u00e9mirat d'Abu Dhabi a annonc\u00e9 vendredi l'arrestation de plus de 100 personnes pour avoir film\u00e9 et diffus\u00e9 des \"informations trompeuses\" sur la guerre, alors que les pays du Golfe intensifient leur contr\u00f4le des publications li\u00e9es aux attaques iraniennes.<\/p><p><br><\/p><p>Les interpellations concernent \"109 individus de diverses nationalit\u00e9s qui ont film\u00e9 des lieux et des incidents et diffus\u00e9 des informations trompeuses sur les r\u00e9seaux sociaux pendant les \u00e9v\u00e9nements actuels\", selon un communiqu\u00e9 publi\u00e9 sur X.<\/p>","tags":[],"type":"html","title":"Plus de 100 personnes arr\u00eat\u00e9es \u00e0 Abu Dhabi pour avoir film\u00e9 et diffus\u00e9 des informations \"trompeuses\" sur la guerre","priority":"normal","createdAt":"2026-03-20T11:46:05.137000Z","titlelink":"","updatedAt":"2026-03-20T11:49:25.715000Z"},{"id":"Y6gDUc2MIRdIu5aDja0i","body":"<p><img src=\"https:\/\/cdn.eu.getarena.im\/cm\/69bd2850f3117ef508d9b04a.JPG\"><\/p><p>Un policier isra\u00e9lien inspecte un fragment de missile iranien dans un salon, apr\u00e8s les tirs de missiles iraniens vers Isra\u00ebl, dans le contexte du conflit isra\u00e9lo-am\u00e9ricain, \u00e0 Rehovot, en Isra\u00ebl, le 20 mars 2026. <span style=\"color: rgb(69, 76, 95); background-color: rgba(251, 250, 253, 0.016);\">\u00a9&nbsp;Reuters<\/span><\/p>","tags":[],"type":"html","title":"\ud83d\udcf8 En image : une attaque iranienne \u00e0 Rehovot, en Isra\u00ebl","priority":"normal","createdAt":"2026-03-20T11:03:34.811000Z","titlelink":"","updatedAt":"2026-03-20T11:49:38.954000Z"},{"id":"5u1NUNi99WObOVdE8mBu","body":"<p>L'arm\u00e9e isra\u00e9lienne a annonc\u00e9 avoir entam\u00e9 des frappes visant des cibles \"du r\u00e9gime terroriste iranien\" dans la r\u00e9gion de Nour, situ\u00e9e sur les rives de la mer Caspienne, en Iran.<\/p><p><br><\/p>","tags":[],"type":"html","title":"L'arm\u00e9e isra\u00e9lienne annonce \u00eatre en train de frapper la r\u00e9gion de Nour, en Iran","priority":"normal","createdAt":"2026-03-20T10:24:33.691000Z","titlelink":"","updatedAt":"2026-03-20T12:16:23.336000Z"},{"id":"14E2uRXDYIPnZXdabvRT","body":"<p>Les \u00c9tats-Unis et Isra\u00ebl ont bombard\u00e9 16 navires iraniens dans des cit\u00e9s portuaires iraniennes du Golfe, selon les autorit\u00e9s locales, cit\u00e9es par l'agence de presse Tasnim.<\/p><p><br><\/p><p>\"\u00c0 la suite d'une attaque a\u00e9rienne am\u00e9ricano-sioniste, au moins 16 navires appartenant \u00e0 des citoyens des villes de Bandar Lengeh et Bandar-e Kong ont \u00e9t\u00e9 enti\u00e8rement d\u00e9truits\", a indiqu\u00e9 un responsable de la province d'Hormozgan, dans le sud du pays.<\/p><p><br><\/p>","tags":[],"type":"html","title":"Seize navires iraniens frapp\u00e9s dans un port du Golfe, selon des m\u00e9dias iraniens","priority":"normal","createdAt":"2026-03-20T10:23:44.248000Z","titlelink":"","updatedAt":"2026-03-20T10:50:26.213000Z"},{"id":"wFbRXR3BltLUSD3qRYI6","body":"<p>Ce jour est un A\u00efd \"triste et douloureux\" pour les musulmans de la ville de J\u00e9rusalem qui n'ont pas acc\u00e8s \u00e0 la mosqu\u00e9e Al-Aqsa, troisi\u00e8me lieu saint de l'islam, sur l'esplanade des Mosqu\u00e9es. Depuis le d\u00e9but de la guerre, les autorit\u00e9s isra\u00e9liennes ont interdit l'acc\u00e8s aux lieux saints de la Vieille Ville pour des raisons de s\u00e9curit\u00e9.<\/p>","tags":[],"type":"oembed-general","title":"\u2b07\ufe0f La f\u00eate de l'A\u00efd el-Fitr marque la fin du ramadan dans le monde","priority":"normal","createdAt":"2026-03-20T10:23:09.987000Z","titlelink":"https:\/\/www.france24.com\/fr\/moyen-orient\/20260320-en-images-guerre-moyen-orient-f%C3%AAte-a%C3%AFd-el-fitr-c%C3%A9l%C3%A9br%C3%A9e-dans-le-monde-musulman-islam-ramadan","updatedAt":"2026-03-20T10:24:40.732000Z"},{"id":"tEa3O6xZS2KT3ENNpcHu","body":"<p>Le ministre fran\u00e7ais des Affaires \u00e9trang\u00e8res, Jean-No\u00ebl Barrot, rencontre son homologue isra\u00e9lien, Gideon Saar, \u00e0 J\u00e9rusalem dans le cadre des efforts de Paris pour faire baisser les tensions r\u00e9gionales.<\/p><p><br><\/p><p>Les deux hommes ont \u00e9chang\u00e9 une poign\u00e9e de mains devant la presse vers 10&nbsp;h&nbsp;45 (8&nbsp;h&nbsp;45 GMT) \u00e0 l'h\u00f4tel King David avant de se r\u00e9unir \u00e0 huis clos, a constat\u00e9 un vid\u00e9aste de l'AFPTV.<\/p><p><br><\/p><p><img src=\"https:\/\/cdn.eu.getarena.im\/cm\/69bd1c0869f3d0397abb5b4f.JPG\"><\/p><p>Le ministre fran\u00e7ais des Affaires \u00e9trang\u00e8res, Jean-No\u00ebl Barrot, serre la main de son homologue isra\u00e9lien, Gideon Saar, lors de leur rencontre \u00e0 J\u00e9rusalem le 20 mars 2026. \u00a9 Reuters<\/p>","tags":[],"type":"html","title":"Jean-No\u00ebl Barrot est arriv\u00e9 \u00e0 J\u00e9rusalem","priority":"normal","createdAt":"2026-03-20T10:06:50.146000Z","titlelink":"","updatedAt":"2026-03-20T10:13:59.661000Z"},{"id":"eO1WpbbFzUq3KPg5GPhw","body":"<p>Le pr\u00e9sident syrien Ahmed al-Charaa a d\u00e9clar\u00e9 qu'il \u0153uvrait \u00e0 maintenir son pays \u00e0 l'\u00e9cart du conflit qui s'\u00e9largit au Moyen-Orient et a assur\u00e9 que Damas \u00e9tait en accord avec tous les pays de la r\u00e9gion.&nbsp;&nbsp;&nbsp;&nbsp;<\/p><p><br><\/p><p>\"Nous pesons nos actes avec une extr\u00eame prudence et \u0153uvrons \u00e0 \u00e9loigner la Syrie de tout conflit\", a-t-il d\u00e9clar\u00e9 apr\u00e8s la pri\u00e8re de l'A\u00efd el-Fitr au palais pr\u00e9sidentiel de Damas.&nbsp;<\/p>","tags":[],"type":"html","title":"Le pr\u00e9sident syrien veut maintenir son pays \u00e0 l'\u00e9cart de la guerre r\u00e9gionale","priority":"normal","createdAt":"2026-03-20T09:34:50.809000Z","titlelink":"","updatedAt":"2026-03-20T10:13:19.312000Z"},{"id":"x03SyysBHbwaY7aqMGem","body":"<p><img src=\"https:\/\/cdn.eu.getarena.im\/cm\/69bd0c9ae57157993aeb595d.jpg\"><\/p><p>Une vue g\u00e9n\u00e9rale de la raffinerie de Mina Al-Ahmadi au Kowe\u00eft, le 20 mars 2026. \u00a9 AP<\/p>","tags":[],"type":"html","title":"\ud83d\udcf8 En image : la raffinerie touch\u00e9e par des frappes de drones iraniens au Kowe\u00eft","priority":"normal","createdAt":"2026-03-20T09:02:51.473Z","reactions":{"clap":0,"thumbsUp":2,"thumbsDown":0},"updatedAt":"2026-03-20T09:02:51.473Z","backgroundColor":"transparent"},{"id":"OkO73RhqOyZRzXV7pewp","body":"<p>Le ministre iranien des Affaires \u00e9trang\u00e8res a d\u00e9nonc\u00e9 samedi, lors d'un appel avec son homologue britannique Yvette Cooper, l'utilisation par les \u00c9tats-Unis des bases militaires britanniques, y voyant une complicit\u00e9 de Londres dans la guerre.<\/p><p><br><\/p><p>\"Ces actions seront certainement consid\u00e9r\u00e9es comme une participation \u00e0 l'agression et resteront grav\u00e9es dans l'histoire des relations entre les deux pays\", a d\u00e9clar\u00e9 Abbas Araghchi, selon un communiqu\u00e9 de son minist\u00e8re.<\/p><p><br><\/p><p>Le gouvernement britannique a donn\u00e9 d\u00e9but mars son feu vert \u00e0 un usage strictement \"d\u00e9fensif\" de ses bases pour frapper des sites de missiles iraniens, apr\u00e8s avoir \u00e9t\u00e9 <a href=\"https:\/\/www.france24.com\/fr\/moyen-orient\/20260302-frappes-en-iran-keir-starmer-assume-avoir-refus%C3%A9-l-usage-d-une-base-britannique-par-les-%C3%A9tats-unis-guerre-moyen-orient\" rel=\"noopener noreferrer\" target=\"_blank\">durement critiqu\u00e9 par le pr\u00e9sident am\u00e9ricain Donald Trump<\/a> pour son refus initial.<\/p>","tags":[],"type":"html","title":"L'Iran accuse Londres de complicit\u00e9 dans \"l'agression\" isra\u00e9lo-am\u00e9ricaine","priority":"normal","createdAt":"2026-03-20T08:25:19.021000Z","titlelink":"","updatedAt":"2026-03-20T10:12:38.453000Z"},{"id":"79WbCZgOOfZdNWDP1KKp","body":"<p><br><\/p>","tags":[],"type":"oembed-youtube","media":{"url":"https:\/\/www.youtube.com\/watch?v=r3RyaUCsP5w","html":"<iframe width=\"200\" height=\"113\" src=\"https:\/\/www.youtube.com\/embed\/r3RyaUCsP5w?feature=oembed\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen title=\"Donald Trump pr\u00e9sente la guerre et la mort en Iran comme un jeu vid\u00e9o \u2022 FRANCE 24\"><\/iframe>","title":"Donald Trump pr\u00e9sente la guerre et la mort en Iran comme un jeu vid\u00e9o \u2022 FRANCE 24","author":{"url":"https:\/\/www.youtube.com\/@FRANCE24","name":"FRANCE 24"},"provider":{"url":"https:\/\/www.youtube.com\/","name":"YouTube"},"thumbnail":"https:\/\/i.ytimg.com\/vi\/r3RyaUCsP5w\/mqdefault.jpg"},"title":"\ud83d\udcf0 Dans la revue de presse de ce vendredi 20 mars","priority":"normal","createdAt":"2026-03-20T08:12:20.337Z","reactions":{"clap":0,"thumbsUp":0,"thumbsDown":0},"updatedAt":"2026-03-20T10:00:57.610Z","backgroundColor":"transparent"},{"id":"3IaLEl6Gub4bIKZHf0qP","body":"<p>Les Gardiens de la r\u00e9volution iraniens ont annonc\u00e9 la mort de leur porte parole, Ali Mohammad Na\u00efni, dans des frappes am\u00e9ricano-isra\u00e9liennes.<\/p><p><br><\/p><p>Il \"est tomb\u00e9 en martyr lors de la l\u00e2che attaque terroriste criminelle perp\u00e9tr\u00e9e par le camp am\u00e9ricano-sioniste \u00e0 l'aube\", ont d\u00e9clar\u00e9 les Gardiens dans un communiqu\u00e9 publi\u00e9 sur leur site Web, Sepah News.<\/p>","tags":[],"type":"html","title":"Les Gardiens de la r\u00e9volution annoncent la mort de leur porte-parole dans des frappes isra\u00e9lo-am\u00e9ricaines","action":{"icon":"https:\/\/stationfy.imgix.net\/pbpicons\/important.png","label":"Important"},"priority":"normal","createdAt":"2026-03-20T07:59:21.654Z","reactions":{"clap":0,"thumbsUp":7,"thumbsDown":0},"updatedAt":"2026-03-20T08:22:43.149Z","backgroundColor":"transparent"},{"id":"23a0AqhezpQaSmnlJHQA","body":"<p>\u2060Le minist\u00e8re chinois des Affaires \u00e9trang\u00e8res a exhort\u00e9 toutes les parties impliqu\u00e9es dans le conflit \u00e0 garantir un approvisionnement en p\u00e9trole stable et sans entrave. Le porte-parole du minist\u00e8re, Lin Jian, n\u2019a mentionn\u00e9 aucun pays en particulier.<\/p><p><br><\/p><p>Ses remarques font suite \u00e0 la d\u00e9claration du secr\u00e9taire au Tr\u00e9sor Scott Bessent, qui a indiqu\u00e9 la veille que les \u00c9tats-Unis pourraient lever les sanctions sur le p\u00e9trole iranien bloqu\u00e9 sur des p\u00e9troliers en mer, afin de contenir la hausse des prix du p\u00e9trole.<\/p>","tags":[],"type":"html","title":"La Chine exhorte les pays \u00e0 garantir un approvisionnement en p\u00e9trole stable et sans entrave","priority":"normal","createdAt":"2026-03-20T07:54:29.913Z","reactions":{"clap":0,"thumbsUp":5,"thumbsDown":0},"updatedAt":"2026-03-20T08:03:12.918Z","backgroundColor":"transparent"},{"id":"8nRFxvFWEVZ6bo1vYj7t","body":"<p>Le pr\u00e9sident libanais Joseph Aoun a appel\u00e9 \u00e0 une tr\u00eave et \u00e0 des n\u00e9gociations avec Isra\u00ebl. Notre correspondant \u00e0 Beyrouth Serge Berberi revient sur ces d\u00e9clarations.<\/p>","tags":[],"type":"oembed-youtube","media":{"url":"https:\/\/www.youtube.com\/watch?v=YRLLvlJwEK0","html":"<iframe width=\"200\" height=\"113\" src=\"https:\/\/www.youtube.com\/embed\/YRLLvlJwEK0?feature=oembed\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen title=\"Guerre au Moyen-Orient : le Liban pousse pour un cessez-le-feu avec Isra\u00ebl \u2022 FRANCE 24\"><\/iframe>","title":"Guerre au Moyen-Orient : le Liban pousse pour un cessez-le-feu avec Isra\u00ebl \u2022 FRANCE 24","author":{"url":"https:\/\/www.youtube.com\/@FRANCE24","name":"FRANCE 24"},"provider":{"url":"https:\/\/www.youtube.com\/","name":"YouTube"},"thumbnail":"https:\/\/i.ytimg.com\/vi\/YRLLvlJwEK0\/mqdefault.jpg"},"title":"\ud83c\udfa5 \"Le Liban est dans une position tr\u00e8s fragile'\"","priority":"normal","createdAt":"2026-03-20T07:48:32.509Z","reactions":{"clap":0,"thumbsUp":7,"thumbsDown":0},"updatedAt":"2026-03-20T08:02:45.430Z","backgroundColor":"transparent"},{"id":"pKkzZGUgk93Yv0aJspN5","body":"<p>Les Gardiens de la r\u00e9volution ont affirm\u00e9 que la production de missiles se poursuivait en Iran&nbsp;:&nbsp;\"Notre industrie balistique m\u00e9rite une note parfaite. (...) Il n'y a aucune inqui\u00e9tude \u00e0 ce sujet, car m\u00eame en temps de guerre, nous continuons \u00e0 fabriquer des missiles\", a d\u00e9clar\u00e9 le porte-parole des Gardiens, Ali Mohammad Na\u00efni, cit\u00e9 par l'agence de presse Fars.<\/p><p><br><\/p><p>Jeudi, le Premier ministre isra\u00e9lien Benjamin Netanyahu a assur\u00e9 que l'Iran n'avait \"plus la capacit\u00e9 de produire des missiles balistiques\" ni \"celle d'enrichir de l'uranium\".<\/p>","tags":[],"type":"html","title":"L'Iran assure que la production de missiles \"continue\" malgr\u00e9 la guerre","priority":"normal","createdAt":"2026-03-20T07:07:14.098Z","reactions":{"clap":0,"thumbsUp":4,"thumbsDown":0},"updatedAt":"2026-03-20T07:36:10.406Z","backgroundColor":"transparent"},{"id":"uCqIHU9EGhT0Jb7A3H2S","body":"<p>Le Sri Lanka a refus\u00e9 que deux avions de guerre am\u00e9ricains arm\u00e9s soient bas\u00e9s sur son territoire pendant la p\u00e9riode du 4 au 8&nbsp;mars, afin de pr\u00e9server sa neutralit\u00e9 dans la guerre en cours, a r\u00e9v\u00e9l\u00e9 son pr\u00e9sident.<\/p><p><br><\/p><p>\"Ils (les \u00c9tats-Unis, NDLR) voulaient red\u00e9ployer deux avions de guerre arm\u00e9s de huit missiles antinavires d'une base de Djibouti sur l'a\u00e9roport international de Mattala (sud) du 4 au 8&nbsp;mars et nous avons dit non\", a d\u00e9clar\u00e9 Anura Kumara Dissanayake devant le Parlement.<\/p>","tags":[],"type":"html","title":"Le Sri Lanka dit avoir refus\u00e9 des avions de guerre am\u00e9ricains sur son sol en mars","priority":"normal","createdAt":"2026-03-20T07:06:53.182Z","reactions":{"clap":0,"thumbsUp":6,"thumbsDown":0},"updatedAt":"2026-03-20T07:37:01.864Z","backgroundColor":"transparent"},{"id":"4yTiXayxnJwsCekz71yR","body":"<p>L'Iran continue, en repr\u00e9sailles des attaques isra\u00e9liennes, d'attaquer des sites \u00e9nerg\u00e9tiques dans le Golfe. Les explications de notre correspondant Siavosh Ghazi \u00e0 T\u00e9h\u00e9ran en Iran.<\/p>","tags":[],"type":"oembed-youtube","media":{"url":"https:\/\/www.youtube.com\/watch?v=nqvoB11-qrg","html":"<iframe width=\"200\" height=\"113\" src=\"https:\/\/www.youtube.com\/embed\/nqvoB11-qrg?feature=oembed\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen title=\"Au 21e jour du conflit, l&#39;\u00e9nergie reste au c\u0153ur de la guerre au Moyen-Orient \u2022 FRANCE 24\"><\/iframe>","title":"Au 21e jour du conflit, l'\u00e9nergie reste au c\u0153ur de la guerre au Moyen-Orient \u2022 FRANCE 24","author":{"url":"https:\/\/www.youtube.com\/@FRANCE24","name":"FRANCE 24"},"provider":{"url":"https:\/\/www.youtube.com\/","name":"YouTube"},"thumbnail":"https:\/\/i.ytimg.com\/vi\/nqvoB11-qrg\/mqdefault.jpg"},"title":"\ud83c\udfa5 C'est une \"mani\u00e8re de montrer que T\u00e9h\u00e9ran n'accepte pas le franchissement de la ligne rouge\"","priority":"normal","createdAt":"2026-03-20T06:30:38.738Z","reactions":{"clap":0,"thumbsUp":1,"thumbsDown":0},"updatedAt":"2026-03-20T07:41:06.165Z","backgroundColor":"transparent"},{"id":"wMLzSfKUgeHlSBXHmsTb","body":"<p>L'agence officielle libanaise Ani a fait \u00e9tat de frappes isra\u00e9liennes contre plusieurs localit\u00e9s du sud du Liban.&nbsp;\"Des avions de guerre ennemis isra\u00e9liens ont frapp\u00e9 \u00e0 l'aube\" des villes dans les districts de Tyr et de Bint-Jbeil, a indiqu\u00e9 l'agence, ajoutant que les forces isra\u00e9liennes avaient aussi touch\u00e9 cinq autres villes du sud du pays.<\/p>","tags":[],"type":"html","title":"L'agence libanaise fait \u00e9tat de frappes isra\u00e9liennes sur des villes du sud du Liban","priority":"normal","createdAt":"2026-03-20T05:54:24.294Z","reactions":{"clap":0,"thumbsUp":1,"thumbsDown":0},"updatedAt":"2026-03-20T07:37:21.479Z","backgroundColor":"transparent"}]}}]},{"@type":"Article","title":"Moyen-Orient : l'arm\u00e9e am\u00e9ricaine au d\u00e9fi d'une guerre prolong\u00e9e avec l'Iran","entrepriseId":"WBMZ614585-F24-FR-20260319","mainImage":{"mediaPath":"\/media\/display\/2f803cce-23b1-11f1-99e5-005056bfb2b6","filenameWithoutExtension":"000-A3UZ3CQ","originalRatio":1.6,"filename":"000-A3UZ3CQ.jpg"},"introduction":"<p>Entre co\u00fbt exorbitant, stocks de missiles sous tension et fatigue croissante de marins d\u00e9ploy\u00e9s depuis des mois, l\u2019arm\u00e9e am\u00e9ricaine pourrait peiner \u00e0 soutenir dans la dur\u00e9e un conflit aux objectifs encore incertains.<\/p>","surtitle":null,"cartouche":"Analyse","cartoucheTags":[],"mainSound":null,"mainVideo":null,"estimatedReadingTime":469230,"canonicalAbsoluteUrl":"https:\/\/www.france24.com\/fr\/moyen-orient\/20260320-moyen-orient-armee-am\u00e9ricaine-d\u00e9fi-guerre-prolong\u00e9e-avec-iran-trump-munitions","mediaReadingTime":0,"superTags":[{"label":"Moyen-Orient","tid":"102_D64_10"}],"thematicTags":[{"label":"Arm\u00e9e am\u00e9ricaine","tid":"102_D64_16870"},{"label":"\u00c9tats-Unis","tid":"102_D64_2419"},{"label":"Iran","tid":"102_D64_1389